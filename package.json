{
  "name": "wolfram-math-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "wma": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/main.ts",
    "doctor": "tsx src/cli/main.ts doctor",
    "smoke:wolfram": "tsx src/cli/main.ts --direct-wolfram \"2+2\""
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "openai": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
