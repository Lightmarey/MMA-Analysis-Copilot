{
  "name": "wolfram-math-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "wma": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/main.ts",
    "doctor": "tsx src/cli/main.ts doctor",
    "smoke:wolfram": "tsx src/cli/main.ts --direct-wolfram \"2+2\"",
    "theorem:generate": "tsx src/theorems/generate.ts",
    "theorem:lint": "tsx src/theorems/lint.ts",
    "verify": "npm run theorem:lint && npm run test && npm run test:wolfram && npm run build && npm run doctor",
    "test": "npm run check && npm run test:planning && npm run test:llm-planning && npm run test:prompts && npm run test:hooks && npm run test:model-routing && npm run test:theorems && npm run test:input && npm run test:report && npm run test:backend && npm run test:runtime && npm run test:config && npm run test:streaming && npm run test:tools",
    "test:planning": "tsx test/planning.test.ts",
    "test:llm-planning": "tsx test/llm-planning.test.ts",
    "test:prompts": "tsx test/prompts.test.ts",
    "test:hooks": "tsx test/hooks.test.ts",
    "test:model-routing": "tsx test/model-routing.test.ts",
    "test:theorems": "tsx test/theorems.test.ts",
    "test:input": "tsx test/input.test.ts",
    "test:report": "tsx test/report.test.ts",
    "test:backend": "tsx test/backend-mode.test.ts",
    "test:runtime": "tsx test/runtime.test.ts",
    "test:config": "tsx test/config.test.ts",
    "test:streaming": "tsx test/streaming.test.ts",
    "test:tools": "tsx test/tool-registry.test.ts",
    "test:wolfram": "tsx test/wolfram-tools.test.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "openai": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
