{
  "schemaVersion": 1,
  "name": "IntegrationByParts",
  "family": "integration-by-parts",
  "runtime": "GenericTemplate",
  "description": "One-dimensional integration by parts with explicit boundary terms.",
  "matchers": [
    {
      "name": "OneDimensionalProductDerivative",
      "operator": "Integral",
      "body": { "kind": "DerivativeProduct", "slots": ["u", "v"] },
      "domainSlot": "domain"
    }
  ],
  "orientations": [
    {
      "name": "Equality",
      "direction": "Equal",
      "relation": "Equal",
      "lhs": "$selected",
      "rhs": "BoundaryTerm[$u,$v,$domain] - IBPIntegral[$u,$v,$domain]"
    }
  ],
  "conditions": [
    {
      "predicate": "BoundaryTerm",
      "arguments": ["$u", "$v", "$domain"]
    },
    {
      "predicate": "FunctionSpace",
      "arguments": ["$u", "RegularEnoughForIBP", "$domain"]
    },
    {
      "predicate": "FunctionSpace",
      "arguments": ["$v", "RegularEnoughForIBP", "$domain"]
    },
    {
      "predicate": "MeasurableIntegrable",
      "arguments": [
        [
          {"predicate": "BoundaryTerm", "arguments": ["$u", "$v", "$domain"]},
          {"predicate": "IBPIntegral", "arguments": ["$u", "$v", "$domain"]}
        ],
        "$domain"
      ]
    }
  ],
  "compatibleHeuristics": []
}
