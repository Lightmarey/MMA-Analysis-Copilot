{
  "schemaVersion": 1,
  "name": "Holder",
  "family": "holder-product-inequality",
  "runtime": "GenericTemplate",
  "description": "Holder inequality for integral or sum products.",
  "parameters": [
    {
      "name": "p",
      "default": 2
    },
    {
      "name": "q",
      "default": 2
    }
  ],
  "matchers": [
    {
      "name": "IntegralProduct",
      "operator": "Integral",
      "body": {
        "kind": "Product",
        "slots": [
          "f",
          "g"
        ]
      },
      "domainSlot": "domain"
    },
    {
      "name": "SumProduct",
      "operator": "Sum",
      "body": {
        "kind": "Product",
        "slots": [
          "f",
          "g"
        ]
      },
      "domainSlot": "domain"
    }
  ],
  "derivedBindings": {
    "bound": "NormIntegral[$f,$p,$domain] * NormIntegral[$g,$q,$domain]"
  },
  "orientations": [
    {
      "name": "AbsUpper",
      "direction": "Auto",
      "relation": "LessEqual",
      "lhs": "Abs[$selected]",
      "rhs": "$bound"
    },
    {
      "name": "SignedUpper",
      "direction": "Upper",
      "relation": "LessEqual",
      "lhs": "$selected",
      "rhs": "$bound",
      "conditions": [
        {
          "predicate": "RealValued",
          "arguments": [
            "$selected"
          ]
        }
      ]
    },
    {
      "name": "SignedLower",
      "direction": "Lower",
      "relation": "LessEqual",
      "lhs": "-$bound",
      "rhs": "$selected",
      "conditions": [
        {
          "predicate": "RealValued",
          "arguments": [
            "$selected"
          ]
        }
      ]
    },
    {
      "name": "SignedTwoSided",
      "direction": "TwoSided",
      "relation": "LessEqualChain",
      "terms": [
        "-$bound",
        "$selected",
        "$bound"
      ],
      "conditions": [
        {
          "predicate": "RealValued",
          "arguments": [
            "$selected"
          ]
        }
      ]
    }
  ],
  "conditions": [
    {
      "predicate": "Greater",
      "arguments": [
        "$p",
        1
      ]
    },
    {
      "predicate": "Greater",
      "arguments": [
        "$q",
        1
      ]
    },
    {
      "predicate": "ExponentConjugacy",
      "arguments": [
        "$p",
        "$q"
      ]
    },
    {
      "predicate": "FunctionSpace",
      "arguments": [
        "$f",
        {
          "kind": "Lp",
          "args": [
            "$p",
            "$domain"
          ]
        }
      ]
    },
    {
      "predicate": "FunctionSpace",
      "arguments": [
        "$g",
        {
          "kind": "Lp",
          "args": [
            "$q",
            "$domain"
          ]
        }
      ]
    },
    {
      "predicate": "Measurable",
      "arguments": [
        "$f",
        "$domain"
      ]
    },
    {
      "predicate": "Measurable",
      "arguments": [
        "$g",
        "$domain"
      ]
    }
  ],
  "compatibleHeuristics": [
    "ExplicitProduct",
    "SplitSqrt",
    "MultiplyByOne"
  ]
}