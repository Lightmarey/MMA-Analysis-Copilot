{
  "schemaVersion": 1,
  "name": "Young",
  "family": "pointwise-product-inequality",
  "runtime": "GenericTemplate",
  "description": "Young inequality for pointwise products.",
  "parameters": [
    { "name": "p" },
    { "name": "q" },
    { "name": "epsilon", "optional": true }
  ],
  "matchers": [
    {
      "name": "PointwiseProduct",
      "body": { "kind": "Product", "slots": ["a", "b"] }
    }
  ],
  "derivedBindings": {
    "standardBound": "Abs[$a]^$p/$p + Abs[$b]^$q/$q",
    "epsilonBound": "$epsilon Abs[$a]^$p + YoungConstant[$epsilon,$p,$q] Abs[$b]^$q"
  },
  "orientations": [
    {
      "name": "AbsUpper",
      "direction": "Auto",
      "relation": "LessEqual",
      "lhs": "Abs[$selected]",
      "rhs": "$standardBound"
    },
    {
      "name": "SignedUpper",
      "direction": "Upper",
      "relation": "LessEqual",
      "lhs": "$selected",
      "rhs": "$standardBound",
      "conditions": [
        {
          "predicate": "RealValued",
          "arguments": ["$selected"]
        }
      ]
    },
    {
      "name": "SignedLower",
      "direction": "Lower",
      "relation": "LessEqual",
      "lhs": "-$standardBound",
      "rhs": "$selected",
      "conditions": [
        {
          "predicate": "RealValued",
          "arguments": ["$selected"]
        }
      ]
    },
    {
      "name": "SignedTwoSided",
      "direction": "TwoSided",
      "relation": "LessEqualChain",
      "terms": ["-$standardBound", "$selected", "$standardBound"],
      "conditions": [
        {
          "predicate": "RealValued",
          "arguments": ["$selected"]
        }
      ]
    }
  ],
  "conditions": [
    {
      "predicate": "Greater",
      "arguments": ["$p", 1]
    },
    {
      "predicate": "Greater",
      "arguments": ["$q", 1]
    },
    {
      "predicate": "ExponentConjugacy",
      "arguments": ["$p", "$q"]
    }
  ],
  "compatibleHeuristics": ["ExplicitProduct", "SplitSqrt", "MultiplyByOne"]
}
