{
  "schemaVersion": 1,
  "name": "SplitSqrt",
  "description": "Rewrite a single integrand body h as Sqrt[h] * Sqrt[h] before applying product inequalities.",
  "appliesTo": ["Holder", "CauchySchwarz"],
  "matchers": [
    {
      "name": "IntegralSingleBody",
      "operator": "Integral",
      "bodySlot": "h",
      "domainSlot": "domain"
    },
    {
      "name": "SumSingleBody",
      "operator": "Sum",
      "bodySlot": "h",
      "domainSlot": "domain"
    }
  ],
  "rewrite": {
    "template": "Integral[Product[Sqrt[$h],Sqrt[$h]],$domain]"
  },
  "conditions": ["Nonnegative[$h]"],
  "cost": 1,
  "maxApplications": 1
}
